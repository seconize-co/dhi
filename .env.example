# ============================================================================
# Dhi Environment Variables
# धी - Runtime Security for AI Agents
# ============================================================================
#
# Copy this file to: .env
# Or export variables directly in your shell
#
# Environment variables override config file settings
# ============================================================================

# ----------------------------------------------------------------------------
# CORE SETTINGS
# ----------------------------------------------------------------------------

# Protection level: log, alert, block
DHI_PROTECTION_LEVEL=alert

# HTTP port for metrics/API server
DHI_METRICS_PORT=9090

# Proxy port for AI tool traffic interception
DHI_PROXY_PORT=8080

# ----------------------------------------------------------------------------
# ALERTING
# ----------------------------------------------------------------------------

# Slack webhook URL for real-time alerts
# Get yours at: https://api.slack.com/messaging/webhooks
# DHI_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Custom webhook URL (receives JSON POST)
# DHI_WEBHOOK_URL=https://your-siem.example.com/api/alerts

# ----------------------------------------------------------------------------
# BUDGET CONTROLS
# ----------------------------------------------------------------------------

# Global maximum LLM spending (USD)
# DHI_MAX_BUDGET=100.0

# Per-agent daily limit (USD)
# DHI_AGENT_DAILY_LIMIT=10.0

# ----------------------------------------------------------------------------
# SMTP (for email alerts)
# ----------------------------------------------------------------------------

# DHI_SMTP_HOST=smtp.company.com
# DHI_SMTP_PORT=587
# DHI_SMTP_USERNAME=alerts@company.com
# DHI_SMTP_PASSWORD=your-smtp-password
# DHI_SMTP_FROM=dhi-alerts@company.com

# ----------------------------------------------------------------------------
# REPORTING
# ----------------------------------------------------------------------------

# Directory for report output
DHI_REPORT_DIR=/var/log/dhi/reports

# Report format: json, text, both
DHI_REPORT_FORMAT=json

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------

# Log level: debug, info, warn, error
DHI_LOG_LEVEL=info

# Log file path (stdout if not set)
# DHI_LOG_FILE=/var/log/dhi/dhi.log
# Alternative (production hosts):
# DHI_LOG_FILE=/var/log/dhi/dhi.log

# ----------------------------------------------------------------------------
# FEATURE TOGGLES
# ----------------------------------------------------------------------------

# Disable eBPF kernel monitoring
# DHI_NO_EBPF=true

# Disable agentic runtime monitoring
# DHI_NO_AGENTIC=true
